# Clusterfile Editor v3.24.4
# Schema-driven, offline-first web editor for OpenShift cluster configuration files
#
# Build from repo root:
#   podman build -t quay.io/dds/clusterfile-editor:v3.24.4 -f apps/editor/Containerfile .

# UBI9-minimal carries nmstate (required by `openshift-install agent create
# image` for static-network validation) and matches the OS family that
# openshift-install was built against. Smaller than full ubi9.
FROM registry.access.redhat.com/ubi9-minimal:latest

# Security: Create non-root user
RUN groupadd -r editor && useradd -r -g editor editor

# System packages:
#   python3.12 + pip + setuptools — runtime
#   nmstate                       — `openshift-install agent create image` deps
#   tar, gzip, ca-certificates    — for fetching openshift-install from
#                                   mirror.openshift.com and extracting it
RUN microdnf install -y --setopt=tsflags=nodocs \
      python3.12 \
      python3.12-pip \
      python3.12-setuptools \
      nmstate \
      tar \
      gzip \
      ca-certificates \
    && microdnf clean all \
    && ln -sf /usr/bin/python3.12 /usr/local/bin/python \
    && ln -sf /usr/bin/python3.12 /usr/local/bin/python3 \
    && ln -sf /usr/bin/pip3.12 /usr/local/bin/pip \
    && ln -sf /usr/bin/pip3.12 /usr/local/bin/pip3

# Install dependencies
WORKDIR /app

# Install Python dependencies directly (no poetry in production)
RUN pip install --no-cache-dir \
    fastapi[standard] \
    jinja2 \
    yamllint \
    jsonpath-ng \
    jsonschema \
    pyyaml \
    uvicorn \
    passlib

# Copy application code from apps/editor/
COPY --chown=editor:editor apps/editor/app/ /app/app/
COPY --chown=editor:editor apps/editor/static/ /app/static/
COPY --chown=editor:editor apps/editor/APP_VERSION /app/

# Copy schema, samples, and templates from repo root
COPY --chown=editor:editor schema/ /app/schema/
COPY --chown=editor:editor data/ /app/samples/
COPY --chown=editor:editor templates/ /app/templates/
COPY --chown=editor:editor plugins/ /app/plugins/
COPY --chown=editor:editor lib/ /app/lib/

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV SAMPLES_DIR=/app/samples
ENV TEMPLATES_DIR=/app/templates
ENV SCHEMA_DIR=/app/schema

# Switch to non-root user
USER editor

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/healthz')" || exit 1

# Run the application
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
